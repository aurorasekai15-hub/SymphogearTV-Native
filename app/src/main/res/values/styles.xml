<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryDark">@color/color_dark</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:ignore="NewApi">shortEdges</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <style name="AppThemePlayer" parent="AppTheme">
        <item name="background">@android:color/black</item>
        <item name="android:keepScreenOn">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="TrackSelectionDialogThemeOverlay" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="windowNoTitle">false</item>
    </style>

    <style name="SettingsDialogThemeOverlay" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="windowNoTitle">false</item>
        <item name="android:windowSoftInputMode">adjustPan</item>
    </style>

    <style name="ImageButtonBase" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/button_rounded_background</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="ImageButtonControl" parent="ImageButtonBase">
        <item name="android:background">@drawable/button_control_background</item>
        <item name="android:layout_width">@dimen/btn_control_size</item>
        <item name="android:layout_height">@dimen/btn_control_size</item>
    </style>

    <style name="ImageButtonClose" parent="ImageButtonBase">
        <item name="android:background">@drawable/button_lock_background</item>
        <item name="android:layout_width">@dimen/btn_control_size</item>
        <item name="android:layout_height">@dimen/btn_control_size</item>
    </style>

    <style name="ImageButtonMain" parent="ImageButtonBase">
        <item name="android:layout_width">@dimen/btn_main_size</item>
        <item name="android:layout_height">@dimen/btn_main_size</item>
        <item name="android:layout_marginTop">@dimen/btn_main_margin_top</item>
    </style>


    <style name="ResBtn" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">#80f0e6ff</item>
        <item name="android:backgroundTint">#1Affffff</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="TopBtn" parent="Widget.AppCompat.ImageButton">
        <item name="android:layout_width">30dp</item>
        <item name="android:layout_height">30dp</item>
        <item name="android:background">@drawable/button_rounded_background</item>
        <item name="android:tint">#80f0e6ff</item>
        <item name="android:padding">6dp</item>
    </style>

</resources>
