<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/color_gold</item>
        <item name="colorPrimaryDark">@color/color_background</item>
        <item name="colorAccent">@color/color_gold_light</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
    </style>

    <style name="AppThemePlayer" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/color_gold</item>
        <item name="colorPrimaryDark">@color/color_background</item>
        <item name="colorAccent">@color/color_gold_light</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Topbar button -->
    <style name="ImageButtonMain">
        <item name="android:layout_width">34dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:background">@drawable/button_control_background</item>
        <item name="android:padding">7dp</item>
        <item name="android:tint">@color/color_text_secondary</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <!-- Quality resolution button -->
    <style name="ResBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">8sp</item>
        <item name="android:textColor">@color/color_text_secondary</item>
        <item name="android:background">@drawable/res_btn_bg</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="ResBtnActive">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">8sp</item>
        <item name="android:textColor">#080808</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/res_btn_active_bg</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="TextAppearance.OSD" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/osd_text_background</item>
        <item name="android:padding">4dp</item>
    </style>
</resources>
