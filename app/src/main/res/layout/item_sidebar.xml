<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sidebar_item_root"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="10dp"
    android:focusable="true"
    android:clickable="true"
    android:background="?android:selectableItemBackground">

    <View
        android:id="@+id/sidebar_accent"
        android:layout_width="3dp"
        android:layout_height="24dp"
        android:layout_marginEnd="10dp"
        android:background="@color/color_primary"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/sidebar_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:textSize="16sp"
        android:text="TV"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/sidebar_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Nasional"
        android:textColor="#e0f0e6ff"
        android:textSize="13sp"
        android:ellipsize="end"
        android:singleLine="true" />

    <TextView
        android:id="@+id/sidebar_count"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:gravity="center"
        android:text="0"
        android:textColor="#ffffff"
        android:textSize="9sp"
        android:textStyle="bold"
        android:background="@drawable/sidebar_count_badge" />

</LinearLayout>
