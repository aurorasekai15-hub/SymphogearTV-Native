<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="catAdapter" type="com.symphogear.tv.adapter.CategoryAdapter" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/color_background"
        tools:context=".MainActivity">

        <!-- ===== SIDEBAR ===== -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/sidebar_bg">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/sidebar_header_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Symphogear TV"
                    android:fontFamily="@font/capture_it"
                    android:textSize="18sp"
                    android:textColor="@color/color_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REVOLUSION MODE"
                    android:textSize="8sp"
                    android:textColor="@color/color_accent"
                    android:letterSpacing="0.2" />

                <!-- User card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:padding="6dp"
                    android:background="@drawable/user_card_bg">

                    <View
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/user_avatar_bg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User"
                            android:textColor="#f0e6ff"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="5dp"
                                android:background="@drawable/dot_green"
                                android:layout_marginEnd="3dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ONLINE"
                                android:textSize="9sp"
                                android:textColor="#22c55e" />

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Label CHANNEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHANNEL"
                android:textSize="8sp"
                android:textColor="#72e91e8c"
                android:letterSpacing="0.2"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <!-- Category list (diisi dari MainActivity) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sidebar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Footer resolusi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/sidebar_footer_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESOLUSI"
                    android:textSize="8sp"
                    android:textColor="#7200d4ff"
                    android:letterSpacing="0.2"
                    android:paddingBottom="5dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/btn360" style="@style/ResBtn" android:text="360p" />
                    <TextView android:id="@+id/btn720" style="@style/ResBtnActive" android:text="720p" android:layout_marginStart="4dp" />
                    <TextView android:id="@+id/btn1080" style="@style/ResBtn" android:text="1080p" android:layout_marginStart="4dp" />
                    <TextView android:id="@+id/btn4k" style="@style/ResBtn" android:text="4K" android:layout_marginStart="4dp" />
                    <TextView android:id="@+id/btnAuto" style="@style/ResBtn" android:text="Auto" android:layout_marginStart="4dp" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== MAIN CONTENT ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/topbar_bg">

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:text="&#128269;"
                        android:textSize="10sp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/search_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cari channel..."
                        android:textColor="#55f0e6ff"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- LIVE badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/live_badge_bg"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:layout_marginStart="6dp">
                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/dot_red"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE"
                        android:textSize="10sp"
                        android:textColor="@color/color_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Buttons -->
                <ImageButton
                    android:id="@+id/button_search"
                    style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_search"
                    android:layout_marginStart="4dp"
                    app:layout_constraintEnd_toStartOf="@id/button_refresh"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageButton
                    android:id="@+id/button_refresh"
                    style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_refresh"
                    android:layout_marginStart="4dp"
                    app:layout_constraintEnd_toStartOf="@id/button_settings"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageButton
                    android:id="@+id/button_settings"
                    style="@style/ImageButtonMain"
                    android:src="@drawable/ic_refresh"
                    android:layout_marginStart="4dp"
                    app:layout_constraintEnd_toStartOf="@id/button_exit"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageButton
                    android:id="@+id/button_exit"
                    style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_exit"
                    android:layout_marginStart="4dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

            </LinearLayout>

            <!-- Channel list -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_category"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adapter="@{catAdapter}"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:padding="10dp"
                    tools:listitem="@layout/item_category" />

                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/loading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shimmer_auto_start="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">
                        <include layout="@layout/item_category_dummy" />
                        <include layout="@layout/item_category_dummy" />
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>
</layout>
