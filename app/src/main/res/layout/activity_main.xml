<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="catAdapter" type="com.symphogear.tv.adapter.CategoryAdapter" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/color_background"
        tools:context=".MainActivity">

        <!-- ===== SIDEBAR ===== -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/sidebar_bg">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/sidebar_header_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Symphogear TV"
                    android:fontFamily="@font/capture_it"
                    android:textSize="18sp"
                    android:textColor="@color/color_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REVOLUSION MODE"
                    android:textSize="8sp"
                    android:textColor="@color/color_accent"
                    android:letterSpacing="0.15" />

                <!-- User card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:padding="8dp"
                    android:background="@drawable/user_card_bg">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/user_avatar_bg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User"
                            android:textColor="#f0e6ff"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/dot_green"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ONLINE"
                                android:textSize="9sp"
                                android:textColor="#22c55e"
                                android:letterSpacing="0.1" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Label CHANNEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHANNEL"
                android:textSize="8sp"
                android:textColor="#72e91e8c"
                android:letterSpacing="0.2"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <!-- Sidebar category list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sidebar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Footer resolusi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/sidebar_footer_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESOLUSI"
                    android:textSize="8sp"
                    android:textColor="#7200d4ff"
                    android:letterSpacing="0.2"
                    android:paddingBottom="5dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/btn360" style="@style/ResBtn" android:text="360p" />
                    <TextView android:id="@+id/btn720" style="@style/ResBtnActive" android:text="720p" android:layout_marginStart="4dp" />
                    <TextView android:id="@+id/btn1080" style="@style/ResBtn" android:text="1080p" android:layout_marginStart="4dp" />
                    <TextView android:id="@+id/btn4k" style="@style/ResBtn" android:text="4K" android:layout_marginStart="4dp" />
                    <TextView android:id="@+id/btnAuto" style="@style/ResBtn" android:text="Auto" android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== MAIN CONTENT ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/topbar_bg">

                <TextView
                    android:id="@+id/text_current_cat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NASIONAL"
                    android:textColor="@color/color_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginEnd="8dp" />

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <TextView
                        android:id="@+id/search_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cari channel..."
                        android:textColor="#55f0e6ff"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- LIVE badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/live_badge_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginStart="6dp">
                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/dot_red"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE"
                        android:textSize="10sp"
                        android:textColor="@color/color_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/button_search"
                    style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_search"
                    android:layout_marginStart="4dp" />

                <ImageButton
                    android:id="@+id/button_refresh"
                    style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_refresh"
                    android:layout_marginStart="4dp" />

                <ImageButton
                    android:id="@+id/button_settings"
                    style="@style/ImageButtonMain"
                    android:src="@drawable/ic_refresh"
                    android:layout_marginStart="4dp" />

                <ImageButton
                    android:id="@+id/button_exit"
                    style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_exit"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Content area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/main_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- SEDANG TRENDING section -->
                        <LinearLayout
                            android:id="@+id/section_trending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <!-- Trending header -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="\u2605"
                                    android:textSize="14sp"
                                    android:textColor="#ffd700"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SEDANG TRENDING"
                                    android:textColor="#ffd700"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="10dp"
                                    android:background="@drawable/separator_line" />
                            </LinearLayout>

                            <!-- Trending card -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@drawable/trending_card_bg"
                                android:padding="14dp">

                                <!-- Title row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="6dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="&#9889;"
                                        android:textSize="22sp"
                                        android:textColor="#ffd700"
                                        android:layout_marginEnd="10dp" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="SYMPHOGEAR TV \u2014 REVOLUSION"
                                        android:textColor="@color/color_primary"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:letterSpacing="0.05" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="DASH+DRM support. Klik channel untuk play. Long press untuk opsi. Refresh untuk update channel terbaru."
                                    android:textColor="#88f0e6ff"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="12dp" />

                                <!-- Stats bar -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:padding="8dp"
                                        android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="4dp">
                                        <TextView
                                            android:id="@+id/stat_total"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textSize="16sp"
                                            android:textStyle="bold"
                                            android:textColor="#ffd700"
                                            android:fontFamily="monospace" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="TOTAL"
                                            android:textSize="7sp"
                                            android:textColor="#55ffffff"
                                            android:letterSpacing="0.1" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:padding="8dp"
                                        android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="4dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="DASH"
                                            android:textSize="13sp"
                                            android:textStyle="bold"
                                            android:textColor="#ffd700"
                                            android:fontFamily="monospace" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="PROTO"
                                            android:textSize="7sp"
                                            android:textColor="#55ffffff"
                                            android:letterSpacing="0.1" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:padding="8dp"
                                        android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="4dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="DRM"
                                            android:textSize="13sp"
                                            android:textStyle="bold"
                                            android:textColor="#ffd700"
                                            android:fontFamily="monospace" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="SECURE"
                                            android:textSize="7sp"
                                            android:textColor="#55ffffff"
                                            android:letterSpacing="0.1" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:padding="8dp"
                                        android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="4dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="4K"
                                            android:textSize="13sp"
                                            android:textStyle="bold"
                                            android:textColor="#ffd700"
                                            android:fontFamily="monospace" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="MAX"
                                            android:textSize="7sp"
                                            android:textColor="#55ffffff"
                                            android:letterSpacing="0.1" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:gravity="center"
                                        android:padding="8dp"
                                        android:background="@drawable/stats_badge_bg">
                                        <TextView
                                            android:id="@+id/stat_custom"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textSize="16sp"
                                            android:textStyle="bold"
                                            android:textColor="#22c55e"
                                            android:fontFamily="monospace" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="CUSTOM"
                                            android:textSize="7sp"
                                            android:textColor="#55ffffff"
                                            android:letterSpacing="0.1" />
                                    </LinearLayout>

                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Channel list -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adapter="@{catAdapter}"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="10dp"
                            tools:listitem="@layout/item_category" />

                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>

                <!-- Shimmer loading -->
                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/loading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shimmer_auto_start="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">
                        <include layout="@layout/item_category_dummy" />
                        <include layout="@layout/item_category_dummy" />
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>
</layout>
