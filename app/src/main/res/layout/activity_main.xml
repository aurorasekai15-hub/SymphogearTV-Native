<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="catAdapter" type="com.symphogear.tv.adapter.CategoryAdapter"/>
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@drawable/bg_main"
        tools:context=".MainActivity">

        <!-- ===== SIDEBAR ===== -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="210dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/sidebar_bg">

            <!-- Header area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="14dp"
                android:background="@drawable/sidebar_header_bg">

                <!-- Gold accent line -->
                <View android:layout_width="28dp" android:layout_height="2dp"
                    android:background="@color/color_gold" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SYMPHOGEAR"
                    android:textColor="@color/color_gold"
                    android:textSize="14sp" android:textStyle="bold"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TELEVISION"
                    android:textColor="@color/color_text_secondary"
                    android:layout_marginBottom="12dp"/>

                <!-- Status card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:padding="9dp" android:background="@drawable/user_card_bg">

                    <View android:layout_width="7dp" android:layout_height="7dp"
                        android:background="@drawable/dot_green" android:layout_marginEnd="9dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Live Streaming" android:textColor="@color/color_text"
                            android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AKTIF" android:textSize="8sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- KATEGORI label -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="KATEGORI"
                android:paddingStart="16dp" android:paddingTop="12dp" android:paddingBottom="5dp"/>

            <!-- Category list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sidebar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"/>

            <!-- Footer: quality selector -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="8dp" android:paddingBottom="10dp"
                android:background="@drawable/sidebar_footer_bg">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="KUALITAS" android:textSize="7sp"
                    android:paddingBottom="6dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/btn360" style="@style/ResBtn" android:text="360p"/>
                    <TextView android:id="@+id/btn720" style="@style/ResBtnActive" android:text="720p" android:layout_marginStart="3dp"/>
                    <TextView android:id="@+id/btn1080" style="@style/ResBtn" android:text="1080p" android:layout_marginStart="3dp"/>
                    <TextView android:id="@+id/btn4k" style="@style/ResBtn" android:text="4K" android:layout_marginStart="3dp"/>
                    <TextView android:id="@+id/btnAuto" style="@style/ResBtn" android:text="Auto" android:layout_marginStart="3dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Sidebar separator -->
        <View android:layout_width="0.5dp" android:layout_height="match_parent"
            android:background="#18C8A84B"/>

        <!-- ===== MAIN AREA ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:background="@drawable/topbar_bg">

                <!-- Category title with gold accent -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginEnd="14dp">
                    <View android:layout_width="2dp" android:layout_height="18dp"
                        android:background="@color/color_gold" android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/text_current_cat"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SEMUA CHANNEL"
                        android:textColor="@color/color_text" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Search bar (clickable) -->
                <LinearLayout
                    android:id="@+id/search_bar_container"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:focusable="true"
                    android:clickable="true">
                    <TextView android:id="@+id/search_hint"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Cari channel..." android:textColor="#35FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- LIVE badge -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="28dp"
                    android:orientation="horizontal" android:gravity="center"
                    android:background="@drawable/live_badge_bg"
                    android:paddingStart="9dp" android:paddingEnd="9dp"
                    android:layout_marginStart="8dp">
                    <View android:layout_width="5dp" android:layout_height="5dp"
                        android:background="@drawable/dot_red" android:layout_marginEnd="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LIVE" android:textSize="9sp"/>
                </LinearLayout>


                <!-- Real-time clock -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:layout_marginStart="8dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/text_clock"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="00:00" android:textColor="@color/color_gold"
                        android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/text_date"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Senin" android:textColor="#88FFFFFF"
                        android:textSize="8sp"/>
                </LinearLayout>

                                <!-- Action buttons -->
                <ImageButton android:id="@+id/button_search" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_search" android:layout_marginStart="4dp"/>
                <ImageButton android:id="@+id/button_refresh" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_refresh" android:layout_marginStart="4dp"/>
                <ImageButton android:id="@+id/button_settings" style="@style/ImageButtonMain"
                    android:src="@drawable/ic_refresh" android:layout_marginStart="4dp"/>
                <ImageButton android:id="@+id/button_exit" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_exit" android:layout_marginStart="4dp"/>

            </LinearLayout>

            <!-- Bottom border of topbar -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#18C8A84B"/>

            <!-- Content + loading overlay -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">

                <!-- Main scroll content -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/main_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Info card -->
                        <LinearLayout
                            android:id="@+id/section_trending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:background="@drawable/trending_card_bg">

                                <!-- Title row -->
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:orientation="horizontal" android:gravity="center_vertical"
                                    android:layout_marginBottom="14dp">
                                    <View android:layout_width="3dp" android:layout_height="14dp"
                                        android:background="@color/color_gold" android:layout_marginEnd="10dp"/>
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="SYMPHOGEAR TV"
                                        android:textColor="@color/color_text"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="PREMIUM"
                                        android:textSize="8sp" android:textColor="@color/color_gold"
                                        android:background="@drawable/drm_badge_bg"
                                        android:paddingStart="7dp" android:paddingEnd="7dp"
                                        android:paddingTop="3dp" android:paddingBottom="3dp"/>
                                </LinearLayout>

                                <!-- Stats row -->
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                        android:padding="10dp" android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="5dp">
                                        <TextView android:id="@+id/stat_total"
                                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="0" android:textSize="18sp" android:textStyle="bold"
                                            android:textColor="@color/color_gold" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="CHANNEL" android:textSize="7sp"/>
                                    </LinearLayout>

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                        android:padding="10dp" android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="5dp">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="HD" android:textSize="15sp" android:textStyle="bold"
                                            android:textColor="@color/color_gold" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="KUALITAS" android:textSize="7sp"/>
                                    </LinearLayout>

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                        android:padding="10dp" android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="5dp">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="DRM" android:textSize="15sp" android:textStyle="bold"
                                            android:textColor="@color/color_gold" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="SECURE" android:textSize="7sp"/>
                                    </LinearLayout>

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                        android:padding="10dp" android:background="@drawable/stats_badge_bg">
                                        <TextView android:id="@+id/stat_custom"
                                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="0" android:textSize="18sp" android:textStyle="bold"
                                            android:textColor="@color/color_green" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="CUSTOM" android:textSize="7sp"/>
                                    </LinearLayout>

                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Channel grid by category -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adapter="@{catAdapter}"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp"
                            tools:listitem="@layout/item_category"/>

                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>

                <!-- Shimmer loading overlay -->
                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/loading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shimmer_auto_start="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical">
                        <include layout="@layout/item_category_dummy"/>
                        <include layout="@layout/item_category_dummy"/>
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

            </FrameLayout>
        </LinearLayout>

    </LinearLayout>
</layout>
