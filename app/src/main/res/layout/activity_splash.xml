<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_background"
        tools:context=".SplashActivity">

        <!-- ===== RING 1 (outer, pink) ===== -->
        <View
            android:id="@+id/ring1"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:background="@drawable/ring_pink"
            app:layout_constraintBottom_toBottomOf="@id/centerArea"
            app:layout_constraintEnd_toEndOf="@id/centerArea"
            app:layout_constraintStart_toStartOf="@id/centerArea"
            app:layout_constraintTop_toTopOf="@id/centerArea" />

        <!-- ===== RING 2 (mid, cyan) ===== -->
        <View
            android:id="@+id/ring2"
            android:layout_width="310dp"
            android:layout_height="310dp"
            android:background="@drawable/ring_cyan"
            app:layout_constraintBottom_toBottomOf="@id/centerArea"
            app:layout_constraintEnd_toEndOf="@id/centerArea"
            app:layout_constraintStart_toStartOf="@id/centerArea"
            app:layout_constraintTop_toTopOf="@id/centerArea" />

        <!-- ===== RING 3 (inner, gold) ===== -->
        <View
            android:id="@+id/ring3"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/ring_gold"
            app:layout_constraintBottom_toBottomOf="@id/centerArea"
            app:layout_constraintEnd_toEndOf="@id/centerArea"
            app:layout_constraintStart_toStartOf="@id/centerArea"
            app:layout_constraintTop_toTopOf="@id/centerArea" />

        <!-- ===== CENTER AREA (anchor for rings) ===== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/centerArea"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="180dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Emblem (bintang) -->
            <ImageView
                android:id="@+id/emblem"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_emblem_star"
                app:layout_constraintBottom_toTopOf="@+id/titleBlock"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                app:layout_constraintVertical_bias="0.42" />

            <!-- Title block -->
            <LinearLayout
                android:id="@+id/titleBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/emblem"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:id="@+id/titleLine1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENKI ZESSHOU"
                    android:fontFamily="@font/capture_it"
                    android:textSize="28sp"
                    android:textColor="#e91e8c"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/titleLine2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYMPHOGEAR"
                    android:fontFamily="@font/capture_it"
                    android:textSize="36sp"
                    android:textColor="#a855f7"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦  TV REVOLUSION  ✦"
                    android:textSize="10sp"
                    android:textColor="#00d4ff"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Character row -->
            <LinearLayout
                android:id="@+id/charRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/titleBlock"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- Hibiki -->
                <LinearLayout android:id="@+id/charHibiki" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <ImageView android:id="@+id/imgHibiki" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/char_border_pink" android:scaleType="centerCrop" android:clipToOutline="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HIBIKI" android:textSize="7sp" android:textColor="#e91e8c" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <!-- Tsubasa -->
                <LinearLayout android:id="@+id/charTsubasa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <ImageView android:id="@+id/imgTsubasa" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/char_border_cyan" android:scaleType="centerCrop" android:clipToOutline="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TSUBASA" android:textSize="7sp" android:textColor="#00d4ff" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <!-- Chris -->
                <LinearLayout android:id="@+id/charChris" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <ImageView android:id="@+id/imgChris" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/char_border_gold" android:scaleType="centerCrop" android:clipToOutline="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHRIS" android:textSize="7sp" android:textColor="#ffd700" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <!-- Kirika -->
                <LinearLayout android:id="@+id/charKirika" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <ImageView android:id="@+id/imgKirika" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/char_border_purple" android:scaleType="centerCrop" android:clipToOutline="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KIRIKA" android:textSize="7sp" android:textColor="#a855f7" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <!-- Shirabe -->
                <LinearLayout android:id="@+id/charShirabe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/imgShirabe" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/char_border_orange" android:scaleType="centerCrop" android:clipToOutline="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SHIRABE" android:textSize="7sp" android:textColor="#ff6b35" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Maria (baris kedua, tengah) -->
            <LinearLayout
                android:id="@+id/charMaria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/charRow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                <ImageView android:id="@+id/imgMaria" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/char_border_green" android:scaleType="centerCrop" android:clipToOutline="true" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MARIA" android:textSize="7sp" android:textColor="#22c55e" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ===== RIGHT PANEL: loading bar + status ===== -->
        <LinearLayout
            android:id="@+id/loadingPanel"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Loading bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@drawable/bar_track">

                <View
                    android:id="@+id/loadingBar"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:background="@drawable/bar_fill" />

            </FrameLayout>

            <!-- Dot indicator -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">
                <View
                    android:id="@+id/loadDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_cyan"
                    android:layout_gravity="start" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="MEMUAT SISTEM SYMPHOGEAR..."
                android:textColor="#e91e8c"
                android:textSize="9sp"
                android:letterSpacing="0.1"
                tools:text="MEMUAT SISTEM SYMPHOGEAR..." />

            <TextView
                android:id="@+id/textUsers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#00d4ff"
                android:textSize="8sp"
                android:text="aurorasekai15" />

        </LinearLayout>

        <!-- Hidden views required by SplashActivity binding -->
        <TextView
            android:id="@+id/text_presents"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
