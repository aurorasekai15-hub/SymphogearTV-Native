<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_background"
        tools:context=".SplashActivity">

        <!-- RING 1 outer pink -->
        <View
            android:id="@+id/ring1"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:background="@drawable/ring_pink"
            app:layout_constraintBottom_toBottomOf="@id/centerArea"
            app:layout_constraintEnd_toEndOf="@id/centerArea"
            app:layout_constraintStart_toStartOf="@id/centerArea"
            app:layout_constraintTop_toTopOf="@id/centerArea" />

        <!-- RING 2 mid cyan -->
        <View
            android:id="@+id/ring2"
            android:layout_width="310dp"
            android:layout_height="310dp"
            android:background="@drawable/ring_cyan"
            app:layout_constraintBottom_toBottomOf="@id/centerArea"
            app:layout_constraintEnd_toEndOf="@id/centerArea"
            app:layout_constraintStart_toStartOf="@id/centerArea"
            app:layout_constraintTop_toTopOf="@id/centerArea" />

        <!-- RING 3 inner gold -->
        <View
            android:id="@+id/ring3"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/ring_gold"
            app:layout_constraintBottom_toBottomOf="@id/centerArea"
            app:layout_constraintEnd_toEndOf="@id/centerArea"
            app:layout_constraintStart_toStartOf="@id/centerArea"
            app:layout_constraintTop_toTopOf="@id/centerArea" />

        <!-- CENTER AREA -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/centerArea"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="180dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Emblem bintang -->
            <ImageView
                android:id="@+id/emblem"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_emblem_star"
                app:layout_constraintBottom_toTopOf="@+id/titleBlock"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.42"
                app:layout_constraintVertical_chainStyle="packed" />

            <!-- Title -->
            <LinearLayout
                android:id="@+id/titleBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/emblem">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/capture_it"
                    android:letterSpacing="0.05"
                    android:text="SENKI ZESSHOU"
                    android:textColor="#e91e8c"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/capture_it"
                    android:letterSpacing="0.05"
                    android:text="SYMPHOGEAR"
                    android:textColor="#a855f7"
                    android:textSize="36sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:letterSpacing="0.15"
                    android:text="&#10022;  TV REVOLUSION  &#10022;"
                    android:textColor="#00d4ff"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Baris karakter 1 (5 karakter) -->
            <LinearLayout
                android:id="@+id/charRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/titleBlock">

                <LinearLayout android:id="@+id/charHibiki" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/char_circle_pink">
                        <ImageView android:id="@+id/imgHibiki" android:layout_width="54dp" android:layout_height="54dp" android:layout_gravity="center" android:scaleType="centerCrop" android:background="@drawable/char_img_mask" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HIBIKI" android:textSize="7sp" android:textColor="#e91e8c" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/charTsubasa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/char_circle_cyan">
                        <ImageView android:id="@+id/imgTsubasa" android:layout_width="54dp" android:layout_height="54dp" android:layout_gravity="center" android:scaleType="centerCrop" android:background="@drawable/char_img_mask" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TSUBASA" android:textSize="7sp" android:textColor="#00d4ff" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/charChris" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/char_circle_gold">
                        <ImageView android:id="@+id/imgChris" android:layout_width="54dp" android:layout_height="54dp" android:layout_gravity="center" android:scaleType="centerCrop" android:background="@drawable/char_img_mask" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHRIS" android:textSize="7sp" android:textColor="#ffd700" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/charKirika" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                    <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/char_circle_purple">
                        <ImageView android:id="@+id/imgKirika" android:layout_width="54dp" android:layout_height="54dp" android:layout_gravity="center" android:scaleType="centerCrop" android:background="@drawable/char_img_mask" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KIRIKA" android:textSize="7sp" android:textColor="#a855f7" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/charShirabe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/char_circle_orange">
                        <ImageView android:id="@+id/imgShirabe" android:layout_width="54dp" android:layout_height="54dp" android:layout_gravity="center" android:scaleType="centerCrop" android:background="@drawable/char_img_mask" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SHIRABE" android:textSize="7sp" android:textColor="#ff6b35" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Maria (tengah baris kedua) -->
            <LinearLayout
                android:id="@+id/charMaria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/charRow">
                <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/char_circle_green">
                    <ImageView android:id="@+id/imgMaria" android:layout_width="54dp" android:layout_height="54dp" android:layout_gravity="center" android:scaleType="centerCrop" android:background="@drawable/char_img_mask" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MARIA" android:textSize="7sp" android:textColor="#22c55e" android:letterSpacing="0.1" android:layout_marginTop="3dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- RIGHT PANEL: loading bar -->
        <LinearLayout
            android:id="@+id/loadingPanel"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:gravity="start"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@drawable/bar_track">
                <View
                    android:id="@+id/loadingBar"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:background="@drawable/bar_fill" />
            </FrameLayout>

            <View
                android:id="@+id/loadDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/dot_cyan" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.1"
                android:text="MEMUAT SISTEM SYMPHOGEAR..."
                android:textColor="#e91e8c"
                android:textSize="9sp" />

        </LinearLayout>

        <!-- Hidden views required by SplashActivity -->
        <TextView
            android:id="@+id/text_presents"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
