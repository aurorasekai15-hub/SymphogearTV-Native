<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#080808"
        tools:context=".SplashActivity">

        <!-- Top gold line -->
        <View android:id="@+id/lineTop"
            android:layout_width="0dp" android:layout_height="1dp"
            android:background="#C8A84B"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Left branding column -->
        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="56dp"
            android:paddingEnd="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/divider">

            <!-- Overline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREMIUM IPTV"
                android:textColor="#55C8A84B"
                android:textSize="9sp"
                android:layout_marginBottom="14dp"/>

            <!-- App name big -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYMPHOGEAR"
                android:textColor="#C8A84B"
                android:textSize="40sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELEVISION"
                android:textColor="#EEEEEE"
                android:textSize="24sp"
                android:layout_marginBottom="28dp"/>

            <!-- Gold divider -->
            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C8A84B"
                android:layout_marginBottom="28dp"/>

            <!-- Status -->
            <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat..."
                android:textColor="#444444"
                android:textSize="11sp"
                android:layout_marginBottom="12dp"/>

            <!-- Loading bar track -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="2dp"
                android:background="@drawable/bar_track"
                android:layout_marginBottom="24dp">
                <View
                    android:id="@+id/loadingBar"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="@drawable/bar_fill"/>
            </FrameLayout>

            <!-- Contributors -->
            <TextView
                android:id="@+id/textUsers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#25C8A84B"
                android:textSize="8sp"
                android:text=""/>

        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0.5dp"
            android:layout_height="0dp"
            android:background="#18C8A84B"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftColumn"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"/>

        <!-- Right info column -->
        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingEnd="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/divider">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FITUR UNGGULAN"
                android:textColor="#40C8A84B"
                android:textSize="8sp"
                android:layout_marginBottom="18dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Channel Indonesia &amp; Internasional" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Logo channel otomatis" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Kategori terorganisir di sidebar" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Update channel otomatis" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Support DASH &amp; DRM" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Favorit &amp; pencarian channel" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="28dp"/>

            <!-- Status badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/stats_badge_bg">

                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@drawable/dot_green" android:layout_marginEnd="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SIAP DIGUNAKAN" android:textColor="#388E3C"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Hidden views required by SplashActivity.kt -->
        <TextView android:id="@+id/textPresents" android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/textTitle" android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

        <!-- Bottom gold line -->
        <View android:layout_width="0dp" android:layout_height="1dp"
            android:background="#C8A84B"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
